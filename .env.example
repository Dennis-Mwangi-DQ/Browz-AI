# --- LLM (prototype: local Ollama) ---
LLM_PROVIDER=ollama
OLLAMA_API_URL=http://127.0.0.1:11434
# Tool-capable models: qwen2.5:7b (default), llama3.1:8b, mistral:7b
OLLAMA_MODEL=qwen2.5:7b
# Used for FAQ vector search when no OpenAI/OpenRouter key is set
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
AGENT_MAX_TOOL_ITERATIONS=5
AGENT_MAX_TOKENS=2048
AGENT_TEMPERATURE=0.1

# Cloud swap (change LLM_PROVIDER only — no code changes needed):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b
# OPENROUTER_MODEL_DEV=minimax/minimax-m2.5
